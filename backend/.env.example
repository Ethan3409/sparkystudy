# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Stripe keys — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Your Stripe Price ID for the Elite annual plan ($79 CAD)
# Create this at https://dashboard.stripe.com/products → Add product → $79 CAD / year
STRIPE_PRICE_ID=price_YOUR_PRICE_ID_HERE

# Your frontend URL (no trailing slash)
FRONTEND_URL=https://ethan3409.github.io/sparkystudy

# Port (Railway sets this automatically)
PORT=3001

# Support contact form — your private email (never sent to the browser)
CONTACT_EMAIL=your_private_email@gmail.com

# Gmail SMTP for sending support emails
# Use a dedicated Gmail account + App Password (not your real password)
# To create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_USER=your_gmail_account@gmail.com
SMTP_PASS=your_gmail_app_password_here
